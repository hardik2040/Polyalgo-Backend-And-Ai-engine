# --- AI ENGINE CONFIGURATION ---
# No OpenAI API key needed! GPT is accessed for FREE via puter.js in the browser.
# See: https://js.puter.com/v2/ for documentation.

# ─── Polymarket Wallet (Required for real trading) ───────────────────────────
# Your Polygon wallet private key (export from MetaMask → Account Details)
PRIVATE_KEY=0x28e8c34cf5cac404ba4debb80147afa06aefb17d2523806595c57d1a00757e35

# Your wallet address (the public address, not the private key!)
WALLET_ADDRESS=0x4DC18C9DfFe676c919850b53D895755Bf142665a

# Signature type: 0 = EOA/MetaMask, 1 = email/Magic/proxy wallet
SIGNATURE_TYPE=1

# ─── Bot Risk Parameters ──────────────────────────────────────────────────────
# Maximum USDC.e to stake per single trade
MAX_STAKE_USD=10

# Maximum total USDC.e exposure across all open positions
MAX_TOTAL_EXPOSURE=50

# Minimum Expected Value (EV) to consider a trade (e.g., 0.03 = 3% edge)
MIN_EV_THRESHOLD=0.01

# Minimum AI confidence to enter a trade (0.0 - 1.0)
MIN_CONFIDENCE=0.10

# Auto-sell stop-loss trigger (percentage loss, e.g., -40 = -40%)
STOP_LOSS_PCT=-40

# Auto-sell take-profit trigger (percentage gain, e.g., 80 = +80%)
TAKE_PROFIT_PCT=80

# ─── Bot Behavior ─────────────────────────────────────────────────────────────
# Set to "true" to only trade temperature/weather markets (safer, real data)
# Set to "false" to trade ALL Polymarket markets
TRADE_WEATHER_ONLY=false

# How often to scan markets and check positions (seconds)
SCAN_INTERVAL_SEC=30
